<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Cryogenic.GameEngineWindow.ViewModels"
        x:Class="Cryogenic.GameEngineWindow.Views.DuneGameStateWindow"
        x:DataType="vm:DuneGameStateViewModel"
        Title="Dune Game Engine - Live Memory View"
        Width="1000"
        Height="800"
        WindowStartupLocation="CenterScreen">

    <TabControl Margin="10">
        
        <TabItem Header="Player Stats">
            <ScrollViewer>
                <StackPanel Margin="10" Spacing="10">
                    <Grid ColumnDefinitions="200,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto" Margin="0,10,0,0">
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Date &amp; Time:" FontWeight="SemiBold"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding DateTimeDisplay}"/>
                        
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Game Elapsed Time:" FontWeight="SemiBold"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding GameElapsedTimeHex}"/>
                        
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Spice (Total):" FontWeight="SemiBold"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SpiceDisplay}"/>
                        
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Spice Reserve:" FontWeight="SemiBold"/>
                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding SpiceReserveDisplay}"/>
                        
                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Water Reserve:" FontWeight="SemiBold"/>
                        <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding WaterReserveDisplay}"/>
                        
                        <TextBlock Grid.Row="5" Grid.Column="0" Text="Money (Solaris):" FontWeight="SemiBold"/>
                        <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding MoneyDisplay}"/>
                        
                        <TextBlock Grid.Row="6" Grid.Column="0" Text="Charisma:" FontWeight="SemiBold"/>
                        <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding CharismaDisplay}"/>
                        
                        <TextBlock Grid.Row="7" Grid.Column="0" Text="Contact Distance:" FontWeight="SemiBold"/>
                        <TextBlock Grid.Row="7" Grid.Column="1" Text="{Binding ContactDistanceDisplay}"/>
                        
                        <TextBlock Grid.Row="8" Grid.Column="0" Text="Military Strength:" FontWeight="SemiBold"/>
                        <TextBlock Grid.Row="8" Grid.Column="1" Text="{Binding MilitaryStrengthDisplay}"/>
                        
                        <TextBlock Grid.Row="9" Grid.Column="0" Text="Ecology Progress:" FontWeight="SemiBold"/>
                        <TextBlock Grid.Row="9" Grid.Column="1" Text="{Binding EcologyProgressDisplay}"/>
                        
                        <TextBlock Grid.Row="10" Grid.Column="0" Text="Game Stage:" FontWeight="SemiBold"/>
                        <TextBlock Grid.Row="10" Grid.Column="1" Text="{Binding GameStageDisplay}"/>
                        
                        <TextBlock Grid.Row="11" Grid.Column="0" Text="Discovered Sietches:" FontWeight="SemiBold"/>
                        <TextBlock Grid.Row="11" Grid.Column="1" Text="{Binding DiscoveredSietchCountDisplay}"/>
                        
                        <TextBlock Grid.Row="12" Grid.Column="0" Text="Active Troops:" FontWeight="SemiBold"/>
                        <TextBlock Grid.Row="12" Grid.Column="1" Text="{Binding ActiveTroopCountDisplay}"/>
                    </Grid>
                </StackPanel>
            </ScrollViewer>
        </TabItem>

        <TabItem Header="NPCs &amp; Followers">
            <ScrollViewer>
                <StackPanel Margin="10" Spacing="10">
                    <Grid ColumnDefinitions="200,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto" Margin="0,10,0,0">
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Follower 1 ID:" FontWeight="SemiBold"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Follower1Id, StringFormat='0x{0:X2}'}"/>
                        
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Follower 1 Name:" FontWeight="SemiBold"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Follower1Name}"/>
                        
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Follower 2 ID:" FontWeight="SemiBold"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Follower2Id, StringFormat='0x{0:X2}'}"/>
                        
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Follower 2 Name:" FontWeight="SemiBold"/>
                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding Follower2Name}"/>
                        
                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Current Room:" FontWeight="SemiBold"/>
                        <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding CurrentRoomDisplay}"/>
                        
                        <TextBlock Grid.Row="5" Grid.Column="0" Text="World Position X:" FontWeight="SemiBold"/>
                        <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding WorldPosX}"/>
                        
                        <TextBlock Grid.Row="6" Grid.Column="0" Text="World Position Y:" FontWeight="SemiBold"/>
                        <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding WorldPosY}"/>
                        
                        <TextBlock Grid.Row="7" Grid.Column="0" Text="Current Speaker ID:" FontWeight="SemiBold"/>
                        <TextBlock Grid.Row="7" Grid.Column="1" Text="{Binding CurrentSpeakerId, StringFormat='0x{0:X2}'}"/>
                        
                        <TextBlock Grid.Row="8" Grid.Column="0" Text="Current Speaker:" FontWeight="SemiBold"/>
                        <TextBlock Grid.Row="8" Grid.Column="1" Text="{Binding CurrentSpeakerName}"/>
                        
                        <TextBlock Grid.Row="9" Grid.Column="0" Text="Dialogue State:" FontWeight="SemiBold"/>
                        <TextBlock Grid.Row="9" Grid.Column="1" Text="{Binding DialogueStateDisplay}"/>
                    </Grid>
                </StackPanel>
            </ScrollViewer>
        </TabItem>
        
        <TabItem Header="Sietches">
            <Grid RowDefinitions="Auto,*">
                <StackPanel Grid.Row="0" Margin="10">
                    <TextBlock Text="{Binding DiscoveredSietchCountDisplay, StringFormat='Discovered: {0}'}" FontWeight="SemiBold"/>
                </StackPanel>
                <DataGrid Grid.Row="1" ItemsSource="{Binding Sietches}" AutoGenerateColumns="False" IsReadOnly="True" Margin="10">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Index" Binding="{Binding Index}" Width="60"/>
                        <DataGridTextColumn Header="Status" Binding="{Binding Status, StringFormat='0x{0:X2}'}" Width="80"/>
                        <DataGridCheckBoxColumn Header="Discovered" Binding="{Binding IsDiscovered}" Width="80"/>
                        <DataGridTextColumn Header="Spice Field" Binding="{Binding SpiceField}" Width="100"/>
                        <DataGridTextColumn Header="X" Binding="{Binding X}" Width="80"/>
                        <DataGridTextColumn Header="Y" Binding="{Binding Y}" Width="80"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </TabItem>
        
        <TabItem Header="Troops">
            <Grid RowDefinitions="Auto,*">
                <StackPanel Grid.Row="0" Margin="10">
                    <TextBlock Text="{Binding ActiveTroopCountDisplay, StringFormat='Active: {0}'}" FontWeight="SemiBold"/>
                </StackPanel>
                <DataGrid Grid.Row="1" ItemsSource="{Binding Troops}" AutoGenerateColumns="False" IsReadOnly="True" Margin="10">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Index" Binding="{Binding Index}" Width="60"/>
                        <DataGridTextColumn Header="Occupation" Binding="{Binding Occupation, StringFormat='0x{0:X2}'}" Width="80"/>
                        <DataGridTextColumn Header="Type" Binding="{Binding OccupationName}" Width="120"/>
                        <DataGridCheckBoxColumn Header="Active" Binding="{Binding IsActive}" Width="60"/>
                        <DataGridTextColumn Header="Location" Binding="{Binding Location, StringFormat='0x{0:X2}'}" Width="80"/>
                        <DataGridTextColumn Header="Motivation" Binding="{Binding Motivation}" Width="80"/>
                        <DataGridTextColumn Header="Spice" Binding="{Binding SpiceSkill}" Width="60"/>
                        <DataGridTextColumn Header="Army" Binding="{Binding ArmySkill}" Width="60"/>
                        <DataGridTextColumn Header="Ecology" Binding="{Binding EcologySkill}" Width="70"/>
                        <DataGridTextColumn Header="Equipment" Binding="{Binding Equipment, StringFormat='0x{0:X2}'}" Width="80"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </TabItem>
        
        <TabItem Header="HNM Video">
            <ScrollViewer>
                <StackPanel Margin="10" Spacing="10">
                    <Grid ColumnDefinitions="200,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto" Margin="0,10,0,0">
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Video ID:" FontWeight="SemiBold"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding HnmVideoIdDisplay}"/>
                        
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Active Video ID:" FontWeight="SemiBold"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding HnmActiveVideoId, StringFormat='0x{0:X4}'}"/>
                        
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Frame Counter:" FontWeight="SemiBold"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding HnmFrameCounter}"/>
                        
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Counter 2:" FontWeight="SemiBold"/>
                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding HnmCounter2}"/>
                        
                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Finished Flag:" FontWeight="SemiBold"/>
                        <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding HnmFinishedFlag, StringFormat='0x{0:X2}'}"/>
                        
                        <TextBlock Grid.Row="5" Grid.Column="0" Text="Resource Flag:" FontWeight="SemiBold"/>
                        <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding CurrentHnmResourceFlag, StringFormat='0x{0:X2}'}"/>
                        
                        <TextBlock Grid.Row="6" Grid.Column="0" Text="File Offset:" FontWeight="SemiBold"/>
                        <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding HnmFileOffsetDisplay}"/>
                        
                        <TextBlock Grid.Row="7" Grid.Column="0" Text="File Remaining:" FontWeight="SemiBold"/>
                        <TextBlock Grid.Row="7" Grid.Column="1" Text="{Binding HnmFileRemainDisplay}"/>
                    </Grid>
                </StackPanel>
            </ScrollViewer>
        </TabItem>
        
        <TabItem Header="Display">
            <ScrollViewer>
                <StackPanel Margin="10" Spacing="10">
                    <Grid ColumnDefinitions="200,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto" Margin="0,10,0,0">
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Front Framebuffer:" FontWeight="SemiBold"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding FramebufferFrontDisplay}"/>
                        
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Back Framebuffer:" FontWeight="SemiBold"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding FramebufferBackDisplay}"/>
                        
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Active Framebuffer:" FontWeight="SemiBold"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding FramebufferActiveDisplay}"/>
                        
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Screen Buffer:" FontWeight="SemiBold"/>
                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding ScreenBufferDisplay}"/>
                        
                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Transition Bitmask:" FontWeight="SemiBold"/>
                        <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding TransitionBitmaskDisplay}"/>
                    </Grid>
                </StackPanel>
            </ScrollViewer>
        </TabItem>
        
        <TabItem Header="Input">
            <ScrollViewer>
                <StackPanel Margin="10" Spacing="10">
                    <Grid ColumnDefinitions="200,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto" Margin="0,10,0,0">
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Mouse Position X:" FontWeight="SemiBold"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding MousePosX}"/>
                        
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Mouse Position Y:" FontWeight="SemiBold"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding MousePosY}"/>
                        
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Mouse Draw X:" FontWeight="SemiBold"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding MouseDrawPosX}"/>
                        
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Mouse Draw Y:" FontWeight="SemiBold"/>
                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding MouseDrawPosY}"/>
                        
                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Cursor Hide Counter:" FontWeight="SemiBold"/>
                        <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding CursorHideCounter}"/>
                        
                        <TextBlock Grid.Row="5" Grid.Column="0" Text="Map Cursor Type:" FontWeight="SemiBold"/>
                        <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding MapCursorTypeDisplay}"/>
                    </Grid>
                </StackPanel>
            </ScrollViewer>
        </TabItem>
        
        <TabItem Header="Sound">
            <ScrollViewer>
                <StackPanel Margin="10" Spacing="10">
                    <Grid ColumnDefinitions="200,*" RowDefinitions="Auto,Auto" Margin="0,10,0,0">
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Sound Present:" FontWeight="SemiBold"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding IsSoundPresentDisplay}"/>
                        
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="MIDI Func5 Return:" FontWeight="SemiBold"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding MidiFunc5ReturnBxDisplay}"/>
                    </Grid>
                </StackPanel>
            </ScrollViewer>
        </TabItem>
        
    </TabControl>
    
</Window>
